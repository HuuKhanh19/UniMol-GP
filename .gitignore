# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# Virtual environments
venv/
ENV/
env/
.conda/

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Data & Experiments (generated outputs)
# =============================================================================
data/processed/
experiments/
*.log

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!experiments/.gitkeep

# =============================================================================
# Model weights & large binary files
# =============================================================================
*.pt
*.pth
*.pkl
*.ckpt
*.bin

# =============================================================================
# Generated data files
# =============================================================================
*.csv
*.sdf
*.mol2
*.h5
*.hdf5
*.npy
*.npz
*.dat
*.result
*.data

# BUT keep raw data CSVs
!data/raw/*.csv

# =============================================================================
# UniMol source — track ALL code, ignore only artifacts
# =============================================================================
# Pretrained weights (large, download separately)
unimol_source/unimol_tools/weights/

# Build artifacts
unimol_source/*.egg-info/
unimol_source/build/
unimol_source/dist/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp
.env